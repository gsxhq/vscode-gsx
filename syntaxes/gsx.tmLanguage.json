{
  "scopeName": "source.gsx",
  "name": "gsx",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#component"
    },
    {
      "include": "#embedded-f-literal"
    },
    {
      "include": "#fragment"
    },
    {
      "include": "#component-tag"
    },
    {
      "include": "#element-tag"
    },
    {
      "include": "source.go"
    }
