        {
          "name": "string.quoted.double.gsx",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.other.backtick.gsx",
          "begin": "`",
          "end": "`"
        },
        {
          "name": "keyword.operator.assignment.gsx",
          "match": "="
        },
        {
          "name": "entity.other.attribute-name.gsx",
          "match": "[A-Za-z_@:][A-Za-z0-9_.:-]*"
        }
      ]
    },
    "embedded-go-hole": {
      "name": "meta.embedded.block.go.gsx",
      "begin": "@\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.embedded.begin.gsx"
