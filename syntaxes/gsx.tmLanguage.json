        "2": {
          "name": "punctuation.definition.string.begin.gsx"
        }
      },
      "end": "(?<!\\\\)(?:\\\\\\\\)*\\K\\2",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.gsx"
        }
      },
      "contentName": "string.interpolated.gsx",
