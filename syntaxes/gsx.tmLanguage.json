          "include": "#embedded-css-literal"
        },
        {
          "include": "#fragment"
        },
        {
          "include": "#component-tag"
        },
        {
          "include": "#element-tag"
        },
        {
          "include": "source.go"
        }
      ]
    },
    "doctype": {
      "name": "meta.tag.doctype.gsx",
      "match": "(?i)(<!)(DOCTYPE)([^>]*)(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.gsx"
        },
        "2": {
          "name": "keyword.other.doctype.gsx"
        },
        "4": {
          "name": "punctuation.definition.tag.gsx"
        }
      }
    },
    "fragment": {
