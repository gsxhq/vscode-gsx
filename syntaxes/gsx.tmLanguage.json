          "name": "entity.name.type.component.gsx"
        },
        "3": {
          "name": "meta.embedded.line.go.gsx",
          "patterns": [
            {
              "include": "source.go"
            }
          ]
        }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.gsx"
        }
      },
      "patterns": [
        {
          "include": "#attribute"
        }
      ]
    },
    "element-tag": {
      "name": "meta.tag.element.gsx",
      "begin": "(</?)([a-z][a-z0-9-]*)",
