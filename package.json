{
  "name": "gsx",
  "displayName": "gsx",
  "description": "Syntax highlighting and language support for gsx (.gsx) — JSX-style HTML templating for Go.",
  "version": "0.0.8",
  "publisher": "gsxhq",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gsxhq/vscode-gsx"
  },
  "icon": "icons/gsx.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:gsx"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gsx",
        "aliases": [
          "gsx"
        ],
        "extensions": [
          ".gsx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gsx",
        "scopeName": "source.gsx",
        "path": "./syntaxes/gsx.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.go.gsx": "go",
          "meta.embedded.line.go.gsx": "go",
          "meta.embedded.block.js.gsx": "javascript",
          "meta.embedded.block.css.gsx": "css"
        }
      }
    ],
    "configuration": {
      "title": "gsx",
      "properties": {
        "gsx.server.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the gsx binary. Empty = auto-discover (PATH, GOBIN, GOPATH/bin)."
        },
        "gsx.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the communication between VS Code and the gsx language server."
        }
      }
    },
    "commands": [
      {
        "command": "gsx.installServer",
        "title": "gsx: Install/Update Language Server"
      },
      {
        "command": "gsx.restartServer",
        "title": "gsx: Restart Language Server"
      }
    ]
  },
  "scripts": {
    "gen:grammar": "node scripts/build-grammar.mjs",
    "sync:corpus": "node scripts/sync-authoritative-corpus.mjs",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test:unit": "vitest run test/unit",
    "test:corpus": "vitest run test/grammar/authoritative.test.ts",
    "test:grammar": "vscode-tmgrammar-test -g test/grammar/stubs/go.tmLanguage.json -g test/grammar/stubs/javascript.tmLanguage.json -g test/grammar/stubs/css.tmLanguage.json \"test/grammar/**/*.gsx\"",
    "test": "npm run test:unit && npm run test:grammar && npm run test:corpus",
    "test:integration": "npm run compile && tsc -p ./ --outDir out-test && node out-test/test/integration/runTest.js",
    "vscode:prepublish": "npm run gen:grammar && npm run compile",
    "package": "npm run gen:grammar && vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "mocha": "^10.0.0",
    "ovsx": "^0.9.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "vscode-tmgrammar-test": "^0.1.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
